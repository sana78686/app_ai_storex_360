APP_NAME="AI StoreX 360"
# Shown in the central Vue app when set (keep in sync with APP_NAME):
# VITE_APP_NAME="${APP_NAME}"
VITE_APP_NAME="AI StoreX 360"
# Central UI: defaults public/assets/logo/aistorex360-logo.png + favicon.png
# VITE_BRAND_LOGO_URL=/assets/logo/aistorex360-logo.png
# VITE_BRAND_FAVICON_URL=/assets/logo/favicon.png
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
# Production (central app):
# APP_URL=https://my.aistorex360.com
# Tenant wildcard base (tenant-<id>.<base>), e.g. tenant-123.aistorex360.com
# CENTRAL_DOMAIN=aistorex360.com
# Optional: extra central app hostnames (comma-separated), e.g. www.my.aistorex360.com
# CENTRAL_DOMAINS=
# SUPPORT_EMAIL=support@example.com
#
# Optional: lock the central app (my.aistorex360.com, etc.) behind a password. Empty = disabled.
# Tenant store domains are not affected.
# SITE_ACCESS_PASSWORD=
#
# Tenant maintenance endpoints (disable by leaving empty)
# TENANT_SEED_TOKEN=
#
# SPA + Sanctum: must include the browser host (no scheme). Defaults use APP_URL host; add extras if needed.
# SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,my.aistorex360.com
#
# On HTTPS behind Plesk/nginx, set secure session cookies (required for SameSite=None if you use it):
# SESSION_SECURE_COOKIE=true
# (bootstrap/app.php also calls trustProxies(*) so Laravel detects HTTPS correctly.)
#
# Frontend (Vite): production needs public/build/manifest.json. Either commit public/build from
# `npm ci && npm run build`, or run that command on the server after each deploy if Node is installed.

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Central (landlord) mail — Mailgun API (tenant signup / verification / welcome)
MAIL_MAILER=mailgun
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"
MAILGUN_DOMAIN=
MAILGUN_SECRET=
MAILGUN_ENDPOINT=api.mailgun.net
# Alternative: SMTP (set MAIL_MAILER=smtp and fill MAIL_HOST, MAIL_PORT, MAIL_SCHEME, MAIL_USERNAME, MAIL_PASSWORD)
# Tenant → customer mail: tenant dashboard mail settings; applied after TenancyInitialized.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# Optional: override central SPA logo/favicon (defaults: /assets/logo/aistorex360-logo.png, favicon.png)
# VITE_BRAND_LOGO_URL=/assets/logo/aistorex360-logo.png
# VITE_BRAND_FAVICON_URL=/assets/logo/favicon.png

# Central OAuth (Socialite) — never commit real values; use Google Cloud / Meta console
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
# FACEBOOK_REDIRECT_URI=https://my.aistorex360.com/SocialiteApiCallback
