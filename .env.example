APP_NAME="AI StoreX 360"
# Shown in the central Vue app when set (keep in sync with APP_NAME):
# VITE_APP_NAME="${APP_NAME}"
VITE_APP_NAME="AI StoreX 360"
# Optional: public URL to logo image (default uses existing file under public/assets/logo/)
# VITE_BRAND_LOGO_URL=/assets/logo/your-logo.png
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000
# Production: APP_URL=https://my.aistorex360.com
# Optional: override hostname for tenant subdomains if it must differ from APP_URL host
# CENTRAL_DOMAIN=my.aistorex360.com
# Optional: extra central app hostnames (comma-separated), e.g. www.my.aistorex360.com
# CENTRAL_DOMAINS=
# SUPPORT_EMAIL=support@example.com
#
# Optional: lock the central app (my.aistorex360.com, etc.) behind a password. Empty = disabled.
# Tenant store domains are not affected.
# SITE_ACCESS_PASSWORD=
#
# Frontend (Vite): production needs public/build/manifest.json. Either commit public/build from
# `npm ci && npm run build`, or run that command on the server after each deploy if Node is installed.

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
